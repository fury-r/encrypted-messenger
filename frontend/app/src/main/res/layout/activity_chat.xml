<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/screen_background"
    tools:context=".messages.ChatActivity">

    <SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/surface_card"
        android:iconifiedByDefault="false"
        android:paddingHorizontal="8dp"
        android:visibility="gone"
        app:queryHint="@string/search" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/linearlayout"
        android:layout_below="@id/searchView"
        android:clipToPadding="false"
        android:paddingHorizontal="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="85dp"
        android:layout_height="82dp"
        android:layout_centerInParent="true"
        android:indeterminateDrawable="@drawable/progress_bg"
        android:visibility="invisible" />

    <LinearLayout
        android:id="@+id/linearlayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/message_box_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="10dp"
        android:paddingBottom="10dp"
        android:weightSum="100">

        <EditText
            android:id="@+id/messagebox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="74"
            android:background="@android:color/transparent"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/secure_message_hint"
            android:paddingVertical="10dp"
            android:textColor="@color/white"
            android:textColorHint="@color/text_muted" />

        <Button
            android:id="@+id/micButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/capsule"
            android:foreground="?android:attr/selectableItemBackground"
            android:minWidth="0dp"
            android:minHeight="0dp" />

        <ImageView
            android:id="@+id/sendBtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/send_text"
            android:contentDescription="@string/secure_message_hint"
            android:padding="8dp"
            android:src="@drawable/ic_send_black_24dp"
            app:tint="@color/white" />

    </LinearLayout>
</RelativeLayout>
